---
import { getCollection, render } from "astro:content";
import { IconArrowLeft } from "@tabler/icons-react";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
    const posts = await getCollection("blog");
    return posts.map((post) => ({
        params: { slug: post.id },
        props: post,
    }));
}

const post = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} - Blog`}>
    <header class="mx-auto w-4xl px-5.5 py-3">
        <a
            href="/blog"
            class="inline-flex items-center gap-2 rounded-sm px-2 py-1 text-sm font-medium text-text-secondary transition-colors hover:bg-nav-button-hover hover:text-text"
        >
            <IconArrowLeft className="h-4 w-4" />
            <span>Back to Blog</span>
        </a>
    </header>
    <article class="max-w-4xl mx-auto py-4 px-8">
        <header class="mb-4 border-b border-border pb-6">
            <div
                class="flex gap-4 items-center text-sm text-text-secondary mb-1"
            >
                <time class="font-medium"
                    >{
                        post.data.pubDate.toLocaleDateString(undefined, {
                            year: "numeric",
                            month: "long",
                            day: "numeric",
                        })
                    }</time
                >
                <span
                    class="px-2 py-0.5 border border-accent/30 rounded text-xs text-accent bg-accent/5 font-semibold tracking-wide"
                    >{post.data.category}</span
                >
            </div>
            <h1 class="text-5xl font-extrabold mb-2 text-text leading-tight">
                {post.data.title}
            </h1>
            <p class="text-text-secondary font-medium">
                {post.data.author}
            </p>
        </header>

        <div class="prose prose-invert max-w-none">
            <Content />
        </div>
    </article>
</Layout>

<style is:global>
    @reference "../../styles/global.css";

    .prose {
        --tw-prose-body: var(--color-text);
        --tw-prose-headings: var(--color-text);
        --tw-prose-links: var(--color-text-link);
        --tw-prose-bold: var(--color-text);
        --tw-prose-bullets: var(--color-accent);
        --tw-prose-quotes: var(--color-text-secondary);
        --tw-prose-code: var(--color-text);
    }

    .prose h1 {
        @apply text-4xl font-extrabold mt-8 mb-2 w-full border-border-strong border-b pb-3;
    }
    .prose h2 {
        @apply text-3xl mt-6 mb-3 font-bold;
    }
    .prose h3 {
        @apply text-2xl;
    }
    .prose p {
        @apply my-3 leading-relaxed text-text;
    }
    .prose a {
        @apply text-text-link underline decoration-accent/60 underline-offset-3 transition-colors;
    }
    .prose a:hover {
        @apply text-accent decoration-accent;
    }
    .prose a:focus-visible {
        @apply rounded-sm outline-none ring-2 ring-accent/60 ring-offset-2 ring-offset-background-primary decoration-accent;
    }
    .prose ul {
        @apply list-disc list-inside my-6 space-y-3;
    }
    .prose ol {
        @apply list-decimal list-inside my-6 space-y-3;
    }
    .prose li {
        @apply pl-2;
    }
    .prose strong {
        @apply font-bold text-text;
    }
    .prose blockquote {
        @apply border-l-4 border-accent pl-6 italic my-10 text-text-secondary;
    }
    .prose code {
        @apply bg-background-secondary border border-border px-1.5 py-0.5 rounded text-sm font-mono;
    }
    .prose pre {
        @apply bg-background-secondary border border-border p-6 rounded-lg my-8 overflow-x-auto;
    }
    .prose img {
        @apply rounded-lg border border-border my-4;
    }
</style>
