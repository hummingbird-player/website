---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}

const post = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} - Blog`}>
	<div class="max-w-6xl mx-auto px-8 py-12">
	<a href="/blog" class="text-sm text-text-link hover:underline mb-8 flex items-center gap-2">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    Back to Blog
  </a>
	
	<article class="max-w-3xl mx-auto py-12">
		<header class="mb-16 border-b border-border pb-12">
			<div class="flex gap-4 items-center text-sm text-text-secondary mb-4">
				<time class="font-medium">{post.data.pubDate.toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' })}</time>
				<span class="px-2 py-0.5 border border-accent/30 rounded text-xs text-accent bg-accent/5 font-semibold tracking-wide uppercase">{post.data.category}</span>
			</div>
			<h1 class="text-5xl font-bold mb-6 text-text leading-tight">{post.data.title}</h1>
			<p class="text-text-secondary font-medium italic">By {post.data.author}</p>
		</header>

		<div class="prose prose-invert max-w-none">
			<Content />
		</div>
	</article>
	</div>
</Layout>

<style is:global>
  @reference "../../styles/global.css";

  .prose {
    --tw-prose-body: var(--color-text);
    --tw-prose-headings: var(--color-text);
    --tw-prose-links: var(--color-text-link);
    --tw-prose-bold: var(--color-text);
    --tw-prose-bullets: var(--color-accent);
    --tw-prose-quotes: var(--color-text-secondary);
    --tw-prose-code: var(--color-text);
  }

  .prose h1, .prose h2, .prose h3 { @apply font-bold mt-12 mb-6 text-text; }
  .prose h1 { @apply text-4xl; }
  .prose h2 { @apply text-3xl; }
  .prose h3 { @apply text-2xl; }
  .prose p { @apply my-6 leading-relaxed text-text; }
  .prose ul { @apply list-disc list-inside my-6 space-y-3; }
  .prose ol { @apply list-decimal list-inside my-6 space-y-3; }
  .prose li { @apply pl-2; }
  .prose strong { @apply font-bold text-text; }
  .prose blockquote { @apply border-l-4 border-accent pl-6 italic my-10 text-text-secondary; }
  .prose code { @apply bg-background-secondary border border-border px-1.5 py-0.5 rounded text-sm font-mono; }
  .prose pre { @apply bg-background-secondary border border-border p-6 rounded-lg my-8 overflow-x-auto; }
  .prose img { @apply rounded-lg border border-border my-10; }
</style>
