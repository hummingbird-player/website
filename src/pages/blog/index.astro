---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Card from "../../components/Card";

const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout title="Blog">
    <div class="max-w-6xl mx-auto px-8 py-12">
    <h1 class="text-2xl font-bold mb-8 text-text">Blog</h1>

    {
        posts.length === 0 ? (
            <div class="py-20 border-2 border-dashed border-border text-center text-text-secondary rounded-lg">
                No blog posts found.
            </div>
        ) : (
            <div class="grid md:grid-cols-2 gap-12">
                {posts.map((post) => (
                    <Card className="flex flex-col items-start h-full">
                        <div class="flex gap-4 items-center text-sm text-text-secondary mb-4">
                            <span>
                                {post.data.pubDate.toLocaleDateString()}
                            </span>
                            <span class="px-2 py-0.5 border border-accent/30 rounded text-xs text-accent bg-accent/5 font-semibold tracking-wide uppercase">
                                {post.data.category}
                            </span>
                        </div>
                        <h2 class="text-2xl font-bold mb-4 text-text leading-tight group">
                            <a
                                href={`/blog/${post.id}`}
                                class="hover:text-text-link transition-colors"
                            >
                                {post.data.title}
                            </a>
                        </h2>
                        <p class="text-text-secondary mb-8 leading-relaxed line-clamp-3">
                            {post.data.description}
                        </p>
                        <a
                            href={`/blog/${post.id}`}
                            class="mt-auto text-sm font-bold uppercase tracking-widest text-text-link hover:underline decoration-2 underline-offset-4"
                        >
                            Read Post
                        </a>
                    </Card>
                ))}
            </div>
        )
    }
    </div>
</Layout>
