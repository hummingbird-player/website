---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button";

const latestPost = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
)[0];

const latestPostDate = latestPost?.data.pubDate.toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
});
---

<Layout
    title="Hummingbird"
    description="Hummingbird is a modern native music player built in Rust with GPUI for Linux, macOS, and Windows."
>
    <!-- Hero -->
    <section
        class="relative overflow-hidden flex flex-col justify-center items-center pt-12 pb-12 sm:pt-16 sm:pb-14 lg:min-h-[calc(100vh-48px)] lg:py-0"
    >
        <div
            class="pointer-events-none absolute hidden lg:block right-[-10%] top-1/2 w-[72%] -translate-y-1/2 opacity-60"
        >
            <img
                src="/screenshot.png"
                alt="Screenshot of the Hummingbird desktop application"
                class="block w-full h-auto rounded-sm"
            />
        </div>

        <div
            class="relative z-10 w-full mx-auto max-w-6xl px-5 sm:px-8 flex flex-col"
        >
            <div
                class="max-w-2xl rounded-xl border border-border bg-background-secondary px-5 py-6 sm:px-6 sm:py-6"
            >
                <h1
                    class="text-2xl font-bold text-text sm:text-3xl tracking-tight leading-[1.15]"
                >
                    The music player that gets out of your way.
                </h1>
                <p
                    class="mt-3 text-sm leading-7 text-text-secondary sm:mt-4 sm:text-base"
                >
                    Designed for anyone - from beginners trying to get away from
                    streaming to audiophiles browsing their century-spanning
                    collections.
                </p>

                <div class="mt-4 flex flex-col gap-3 sm:flex-row">
                    <Button href="/download" className="px-4 py-1.5 text-sm">
                        Get Hummingbird
                    </Button>
                </div>
            </div>
            {
                latestPost && (
                    <div class="w-full max-w-2xl pt-5 sm:pt-6 relative z-10">
                        <a
                            href={`/blog/${latestPost.id}`}
                            class="group flex flex-col gap-3 rounded-xl border border-border bg-background-secondary px-4 py-3 sm:px-5 sm:py-3.5 md:flex-row md:items-center md:justify-between"
                        >
                            <p class="truncate pr-2 text-sm font-medium text-text sm:text-[15px]">
                                {latestPost.data.title}
                            </p>
                            <div class="flex shrink-0 items-center gap-4 text-xs sm:text-sm">
                                <span class="text-text-secondary">
                                    {latestPostDate}
                                </span>
                                <span class="inline-flex items-center gap-2 font-semibold text-text-link transition-colors group-hover:text-button-primary-hover">
                                    Read post
                                    <span aria-hidden="true">→</span>
                                </span>
                            </div>
                        </a>
                    </div>
                )
            }
        </div>
    </section>

    <section class="bg-background-secondary border-t border-b border-border">
        <div class="mx-auto max-w-6xl py-20 px-8">
            <div class="flex flex-col lg:flex-row lg:justify-between gap-6">
                <h2
                    class="text-4xl font-bold tracking-tight text-text lg:w-[50%]"
                >
                    “Next-generation” doesn't mean giving up on the benefits of
                    the past.
                </h2>
                <div class="leading-6 lg:w-[50%]">
                    Hummingbird is built to take full advantage of modern
                    hardware <b>without</b> being a resource hog. Memory usage is
                    minimized, the application is heavily optimized, and Hummingbird
                    is fully native - no Electron.

                    <div class="mt-2 text-xs text-text-secondary">
                        Hummingbird is still in alpha, so while we believe these
                        performance claims are all true, it doesn't yet live up
                        to its full potential.
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="border-b border-border">
        <div class="mx-auto max-w-6xl py-20 px-8">
            <div class="flex flex-col gap-6 items-center">
                <h2 class="text-4xl font-bold tracking-tight text-text">
                    Faster than you can think.
                </h2>
                <div class="leading-6 lg:w-[70%] text-center">
                    No more waiting around for pictures to load. Everything in
                    Hummingbird is built to happen within 16 milliseconds or
                    less - even on low-end devices. Plus, Hummingbird's scanner
                    is purpose-built to be as fast as possible. Got a modern
                    SSD? Think seconds, not minutes - even if you've got 30
                    thousand tracks.
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="mx-auto max-w-6xl py-20 px-8">
        <div class="px-8 py-12 text-center">
            <h2 class="text-4xl font-bold text-text tracking-tight">
                Ready to try Hummingbird?
            </h2>
            <p
                class="text-text-secondary mt-3 max-w-md mx-auto text-sm leading-6"
            >
                Available now for Linux, macOS, and Windows.
            </p>
            <div class="mt-7">
                <Button href="/download" className="px-5 py-1.5 text-sm">
                    Get Hummingbird
                </Button>
            </div>
        </div>
    </section>
</Layout>
