---
import { getEntry, render } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button";
import Card from "../components/Card";

const platforms = [
    {
        name: "Windows",
        types: [
            {
                name: "64-bit Intel/AMD",
                file_name: "HummingbirdSetup_x86_64.exe",
            },
            {
                name: "64-bit ARM",
                file_name: "HummingbirdSetup_aarch64.exe",
            },
            {
                name: "Portable 64-bit Intel/AMD",
                file_name: "Hummingbird-x86_64.exe",
            },
            {
                name: "Portable 64-bit ARM",
                file_name: "Hummingbird-aarch64.exe",
            },
        ],
    },
    {
        name: "macOS",
        types: [
            {
                name: "64-bit Intel",
                file_name: "hummingbird-intel.dmg",
            },
            {
                name: "Apple Silicon",
                file_name: "hummingbird-arm.dmg",
            },
        ],
    },
    {
        name: "Linux",
        types: [
            {
                name: "64-bit Intel/AMD (AppImage)",
                file_name: "hummingbird-x86_64.AppImage",
            },
            {
                name: "64-bit ARM (AppImage)",
                file_name: "hummingbird-aarch64.AppImage",
            },
        ],
    },
];

const unstableWindowsExcludedFiles = new Set([
    "HummingbirdSetup_x86_64.exe",
    "HummingbirdSetup_aarch64.exe",
]);

const stableBaseUrl =
    "https://github.com/hummingbird-player/hummingbird/releases/latest/download";
const unstableBaseUrl =
    "https://github.com/hummingbird-player/hummingbird/releases/download/latest";

const distributionPackages = await getEntry(
    "download",
    "distribution-packages",
);

if (!distributionPackages) {
    throw new Error("Missing distribution packages content entry.");
}

const { Content: DistributionPackagesContent } =
    await render(distributionPackages);
---

<Layout
    title="Download Hummingbird"
    description="Download Hummingbird for Linux, macOS, and Windows, or install it through Fedora COPR, the AUR, or Nix."
>
    <header class="mx-auto max-w-6xl pt-20 pb-18 px-8">
        <h1 class="text-3xl font-bold tracking-tight text-text sm:text-4xl">
            Get Hummingbird
        </h1>
    </header>

    <section class="bg-background-secondary border-t border-b border-border">
        <div class="mx-auto max-w-6xl py-16 px-8">
            <div class="grid gap-4 lg:grid-cols-3">
                {
                    platforms.map((platform) => (
                        <Card className="flex h-full flex-col px-5 pt-4 pb-5">
                            <div class="border-b border-border">
                                <h3 class="text-lg font-bold text-text">
                                    {platform.name}
                                </h3>
                            </div>

                            <div class="mt-4 flex flex-1 flex-col gap-3">
                                {platform.types.map((type) => (
                                    <Button
                                        href={`${stableBaseUrl}/${type.file_name}`}
                                        className="w-full"
                                    >
                                        {type.name}
                                    </Button>
                                ))}
                            </div>

                            {platform.name === "Linux" && (
                                <div class="pt-5">
                                    <Button
                                        href="#distribution-packages"
                                        variant="secondary"
                                        className="w-full px-4 py-2 text-center"
                                    >
                                        Install via your distribution's package
                                        manager
                                    </Button>
                                </div>
                            )}
                        </Card>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="border-b border-border">
        <div class="mx-auto max-w-6xl px-8 py-14">
            <div>
                <h2 class="text-xl font-bold tracking-tight text-text">
                    Unstable Builds
                </h2>
                <p class="mt-2 text-sm text-text-secondary">
                    <strong class="text-text">Warning:</strong> Unstable builds may
                    be less stable and contain bugs. Use them at your own risk. Windows
                    installers are not built for unstable builds.
                </p>
            </div>

            <div class="mt-6 grid gap-4 lg:grid-cols-3">
                {
                    platforms.map((platform) => {
                        const unstableTypes = platform.types.filter((type) =>
                            platform.name === "Windows"
                                ? !unstableWindowsExcludedFiles.has(
                                      type.file_name,
                                  )
                                : true,
                        );

                        return (
                            <Card className="flex h-full flex-col px-5 py-5">
                                <div class="border-b border-border">
                                    <h3 class="text-base font-bold text-text">
                                        {platform.name}
                                    </h3>
                                </div>

                                <div class="mt-4 flex flex-1 flex-col gap-2.5">
                                    {unstableTypes.map((type) => (
                                        <Button
                                            href={`${unstableBaseUrl}/${type.file_name}`}
                                            variant="secondary"
                                            className="w-full px-4 py-2 text-sm"
                                        >
                                            {type.name}
                                        </Button>
                                    ))}
                                </div>
                            </Card>
                        );
                    })
                }
            </div>
        </div>
    </section>

    <section
        id="distribution-packages"
        class="mx-auto max-w-6xl py-16 px-8 scroll-mt-24"
    >
        <h2 class="text-xl font-bold tracking-tight text-text mb-2">
            Distribution Packages
        </h2>

        <div class="download-doc-content">
            <DistributionPackagesContent />
        </div>
    </section>
</Layout>

<style is:global>
    @reference "../styles/global.css";

    .download-doc-content h3 {
        @apply mt-10 border-t border-border pt-6 text-lg font-bold text-text;
    }

    .download-doc-content p {
        @apply mt-2 leading-6;
    }

    .download-doc-content code {
        @apply rounded-sm border border-border bg-background-secondary px-1.5 py-0.5 text-sm font-mono text-text;
    }

    .download-doc-content pre {
        @apply mt-4 overflow-x-auto rounded-sm border border-border bg-background-primary px-4 py-4 text-sm leading-6 text-text;
    }

    .download-doc-content pre code {
        @apply border-0 bg-transparent p-0;
    }
</style>
